MONGO_URL=mongodb://localhost:27017
DB_NAME=mizan
CORS_ORIGINS=http://localhost:3000

# Azure ML hosted endpoint
USE_AZURE_ENDPOINT=true
AZURE_ML_ENDPOINT=
AZURE_ML_API_KEY=
AZURE_ML_DEPLOYMENT=
AZURE_TEMPERATURE=0
AZURE_MAX_TOKENS=150
AZURE_FREQUENCY_PENALTY=1.1
AZURE_PRESENCE_PENALTY=1.0
AZURE_INCLUDE_SYSTEM_PROMPT=true
AZURE_HISTORY_MAX_MESSAGES=1
AZURE_CONTEXT_WINDOW=1024
MODEL_HTTP_TIMEOUT_SECONDS=180
AZURE_REQUEST_MAX_RETRIES=3
AZURE_RETRY_BACKOFF_BASE=2.0
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
STREAM_KEEPALIVE_SECONDS=10

# Keep local model paths disabled by default
USE_FINETUNED=false
ALLOW_CLAUDE_FALLBACK=false
CHATBOT_LOCAL_URL=
EMERGENT_LLM_KEY=
GEMINI_API_KEY=