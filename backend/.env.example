MONGO_URL=mongodb://localhost:27017
DB_NAME=mizan
CORS_ORIGINS=http://localhost:3000
JWT_SECRET=replace-me-with-a-secure-random-value

# Gemini RAG over the local law dataset
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODEL_CANDIDATES=gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash-002,gemini-1.5-pro,gemini-1.5-pro-002
LAW_DATASET_PATH=../law_dataset.csv
RAG_TOP_K=5
RAG_MAX_CONTEXT_CHARS=6000
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=512
GEMINI_REQUEST_MAX_RETRIES=2
GEMINI_RETRY_BACKOFF_BASE=1.5

MODEL_HTTP_TIMEOUT_SECONDS=300
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
STREAM_KEEPALIVE_SECONDS=10

# Fine-tuned GGUF in-process mode (disabled by default to avoid downloads)
USE_FINETUNED=false
FINETUNED_MODEL_PATH=C:\tmp\mizan-chatbot\mizan-q4_k_m.gguf
FINETUNED_HF_REPO=olaasm/mizan
FINETUNED_HF_FILE=llama-3-8b-instruct.Q4_K_M.gguf
FINETUNED_N_CTX=2048
FINETUNED_N_THREADS=4

# Optional external local chatbot server
CHATBOT_LOCAL_URL=
