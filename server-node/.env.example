PORT=8001
MONGO_URL=mongodb://localhost:27017
DB_NAME=mizan
CORS_ORIGINS=*

# Anthropic key for Claude Sonnet 4.5.
# - If you have a real Anthropic key, paste it here.
# - If you want to use the Emergent universal key, prefer the Python backend
#   at /app/backend which routes through emergentintegrations.
ANTHROPIC_API_KEY=

# Optional: URL of your locally-running quantized Mizan chatbot
# (see /app/chatbot/README.md). When set, the backend will try this first
# and fall back to Claude on failure.
CHATBOT_LOCAL_URL=
